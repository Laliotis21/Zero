# Supabase — copy to .env and fill from your project (Settings → API).
# These are public client values (RLS protects data, not key secrecy), but .env
# is gitignored so they stay out of the repo.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Sentry crash reporting — paste the DSN from your Sentry project
# (Settings → Projects → [project] → Client Keys (DSN)). Leave empty in dev:
# crash reporting stays a silent no-op until this is set. Production builds
# must have it set so crashes are reported.
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat in-app purchases (Pro paywall) — paste the iOS PUBLIC API key from
# the RevenueCat dashboard (Project → API keys → "App-specific" key for the
# Apple App Store; it starts with "appl_"). Leave empty in dev: in-app purchases
# stay a silent no-op (isPro=false, "not available" on tap) until this is set.
# IAP also needs a native/dev build + a sandbox tester — see REVENUECAT_SETUP.md.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
