# Supabase — copy to .env and fill from your project (Settings → API).
# These are public client values (RLS protects data, not key secrecy), but .env
# is gitignored so they stay out of the repo.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Sentry crash reporting — paste the DSN from your Sentry project
# (Settings → Projects → [project] → Client Keys (DSN)). Leave empty in dev:
# crash reporting stays a silent no-op until this is set. Production builds
# must have it set so crashes are reported.
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat in-app purchases (Pro paywall) — paste the PUBLIC API key for each
# platform from the RevenueCat dashboard (Project settings → API keys). The app
# auto-selects the key by platform. Set at least the one for the store you ship.
# Leave empty in dev: in-app purchases stay a silent no-op (isPro=false,
# "not available" on tap) until set. IAP also needs a native/dev build + a store
# test account — see REVENUECAT_SETUP.md.
#   iOS  (Apple App Store) key starts with "appl_"
#   Android (Google Play)  key starts with "goog_"   <-- Android-first launch
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
